# Copy to .env and fill in. Both values below are required for a fresh instance.
#
# Generate a secret:  openssl rand -base64 48   (or, with Elixir: mix phx.gen.secret)
SECRET_KEY_BASE=

# One-time credential for claiming the first admin: openssl rand -hex 32
# Remove this value (and its docker-compose environment entry) after the first account exists.
CINDER_BOOTSTRAP_TOKEN=

# Public hostname/domain Cinder is served on. Keep "localhost" for a local trial;
# set it to your domain once you put Cinder behind a reverse proxy with TLS.
PHX_HOST=localhost

# Host directory holding the whole media tree (library + downloads). It must be ONE
# filesystem so Cinder can hardlink completed downloads into the library.
MEDIA_ROOT=./media

# Optional outer HTTP Basic-auth gate in front of the whole app (set BOTH to enable).
# Useful until you've created your admin account, or as a second layer when Cinder
# isn't behind a reverse proxy/VPN.
# CINDER_BASIC_AUTH_USER=
# CINDER_BASIC_AUTH_PASSWORD=

# --- Optional: bootstrap service config -------------------------------------------
# You normally enter these in the first-run wizard (/setup) instead — they're stored
# in the database (secrets encrypted). Uncomment only to pre-seed an unattended boot;
# the in-app value overrides whatever you set here.
# TMDB_API_TOKEN=
# PROWLARR_URL=http://prowlarr:9696
# PROWLARR_API_KEY=
# QBITTORRENT_URL=http://qbittorrent:8080
# QBITTORRENT_USERNAME=
# QBITTORRENT_PASSWORD=
# SABNZBD_URL=http://sabnzbd:8080
# SABNZBD_API_KEY=
# JELLYFIN_URL=http://jellyfin:8096
# JELLYFIN_API_KEY=
# PLEX_URL=http://plex:32400
# PLEX_TOKEN=
# Plex has no refresh-all endpoint, so each library carries its own numeric section id (the
# number in the Plex web URL for that library) — one per kind:
# MOVIES_PLEX_SECTION=1
# TV_PLEX_SECTION=2
# Subtitles (OpenSubtitles.com) — comma-separated languages, e.g. "en,fr":
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USERNAME=
# OPENSUBTITLES_PASSWORD=
# SUBTITLE_LANGUAGES=
# Optional fallback translation (self-hosted LibreTranslate):
# LIBRETRANSLATE_URL=http://libretranslate:5000
# LIBRETRANSLATE_API_KEY=
# Cues are translated in batches (whole files are too slow for one request on a
# CPU instance). Defaults: 50 cues/batch, 60000 ms/request — tune to your box.
# LIBRETRANSLATE_BATCH_SIZE=50
# LIBRETRANSLATE_TIMEOUT=60000
#
# The library roots are set directly in docker-compose.yml (MOVIES_LIBRARY_PATH=/media/movies,
# TV_LIBRARY_PATH=/media/tv — a separate root per kind, both required); change them there
# or in /settings. Listed here only for non-compose deployments:
# MOVIES_LIBRARY_PATH=/media/movies
# TV_LIBRARY_PATH=/media/tv
